<?xml version="1.0"?>

<initialize name="SR75 cruise test">

  <!-- Initial position -->
  <latitude unit="DEG">32.5378085</latitude>
  <longitude unit="DEG">74.3661944</longitude>

  <!-- High altitude used only for debugging long-duration standalone JSBSim runs.
       Later reduce to 5000 m and 1000 m after trim/aero tuning. -->
  <altitude unit="M">10000</altitude>

  <!-- 69 m/s = approximately 134.1 knots -->
  <vt unit="KTS">134.1</vt>

  <!-- Level flight path initially -->
  <gamma unit="DEG">0.0</gamma>

  <!-- Initial heading -->
  <psi unit="DEG">315</psi>

  <!-- Initial roll and pitch -->
  <phi unit="DEG">0.0</phi>
  <theta unit="DEG">3.0</theta>

</initialize>